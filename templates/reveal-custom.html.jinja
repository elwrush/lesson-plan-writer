<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />

        {% if favicon %}
            <link rel="icon" href="{{ favicon }}">
        {% endif %}

        <link rel="stylesheet" href="{{ revealjs_path }}/dist/reveal.css" />

        {% if theme %}
            <link rel="stylesheet" href="{{ theme }}" />
        {% endif %}
        {% if highlight_theme %}
            <link rel="stylesheet" href="{{ highlight_theme }}" />
        {% endif %}

        {% for plugin in plugins %}
            {% if plugin.extra_css %}
                {% for css in plugin.extra_css %}
                    <link rel="stylesheet" href="{{ css }}" />
                {% endfor %}
            {% endif %}
        {% endfor %}

        <style>
            .reveal .slides section[data-markdown] {
                text-align: left;
                padding: 0 60px;
            }
            .reveal h2 {
                font-size: 1.6em;
                margin-bottom: 0.4em;
                border-bottom: 2px solid #2a76dd;
                padding-bottom: 0.2em;
            }
            .reveal h3 {
                font-size: 1.2em;
                color: #555;
                margin-bottom: 0.3em;
            }
            .reveal ul {
                display: block;
                list-style-type: disc;
            }
            .reveal li {
                margin-bottom: 0.3em;
            }
            .reveal .aim-label {
                font-size: 0.7em;
                color: #888;
                text-transform: uppercase;
                letter-spacing: 0.1em;
            }
            .reveal .stage-header {
                display: flex;
                justify-content: space-between;
                align-items: baseline;
                margin-bottom: 0.4em;
            }
            .reveal .stage-meta {
                font-size: 0.6em;
                color: #888;
            }
            .cefr-badge {
                display: inline-block;
                color: white;
                font-weight: bold;
                padding: 4px 12px;
                border-radius: 4px;
                font-size: 0.4em;
                vertical-align: middle;
                margin-left: 10px;
            }
            .cefr-badge.A1 { background: #4caf50; }
            .cefr-badge.A2 { background: #8bc34a; }
            .cefr-badge.B1 { background: #2196f3; }
            .cefr-badge.B2 { background: #2a76dd; }
            .cefr-badge.C1 { background: #9c27b0; }
            .cefr-badge.C2 { background: #f44336; }
            .reveal .material-ref {
                font-size: 0.65em;
                color: #888;
                font-style: italic;
                margin-top: 0.5em;
            }
            .reveal .answer-block {
                background: #e8f5e9;
                border-left: 4px solid #4caf50;
                padding: 10px 16px;
                margin: 0.5em 0;
            }
            .reveal .answer-block .correct {
                font-weight: bold;
                color: #2e7d32;
            }
            .reveal .answer-block .explanation {
                font-size: 0.85em;
                margin-top: 0.3em;
            }
            .reveal .source-cite {
                font-size: 0.7em;
                color: #666;
                font-style: italic;
                margin-top: 0.3em;
            }
            .reveal .summary-box {
                background: #e3f2fd;
                border-left: 4px solid #2a76dd;
                padding: 16px 20px;
                margin: 0.5em 0;
            }
            .reveal .title-slide {
                text-align: center;
            }
            .reveal .title-slide h1 {
                font-size: 2em;
                margin-bottom: 0.3em;
            }
            .reveal .title-slide .subtitle {
                font-size: 0.8em;
                color: #666;
            }
            .reveal .title-slide .teacher-name {
                font-size: 0.7em;
                color: #888;
                margin-top: 1em;
            }
            .reveal .image-caption {
                font-size: 0.55em;
                color: #888;
                text-align: center;
                margin-top: 0.2em;
            }
            .reveal img {
                max-height: 400px;
                margin: 0 auto;
            }
        </style>
    </head>
    <body>
        <div class="reveal">
            <div class="slides">
                <section data-markdown
                {% for key, value in markdown_data_options.items() %}
                    {{ key }}="{{ value }}"
                {% endfor %}
                >
                    <textarea data-template>
{{ markdown }}
                    </textarea>
                </section>
            </div>
        </div>
        <script src="{{ revealjs_path }}/dist/reveal.js"></script>
        <script src="{{ revealjs_path }}/dist/plugin/highlight.js"></script>
        <script src="{{ revealjs_path }}/dist/plugin/markdown.js"></script>
        <script src="{{ revealjs_path }}/dist/plugin/math.js"></script>
        <script src="{{ revealjs_path }}/dist/plugin/notes.js"></script>
        <script src="{{ revealjs_path }}/dist/plugin/search.js"></script>
        <script src="{{ revealjs_path }}/dist/plugin/zoom.js"></script>

        {% if plugins %}
            {% for plugin in plugins %}
                {% if plugin.extra_javascript %}
                    {% for javascript in plugin.extra_javascript %}
                        <script src="{{ javascript }}"></script>
                    {% endfor %}
                {% endif %}
            {% endfor %}
        {% endif %}

        <script>
            Reveal.initialize({
                {% if revealjs_config %}
                    {% for key, value in revealjs_config.items() %}
                        {{ key }}: {{ value | tojson | safe }},
                    {% endfor %}
                {% endif %}
                plugins: [
                    RevealMarkdown,
                    RevealHighlight,
                    RevealMath.KaTeX,
                    RevealNotes,
                    RevealSearch,
                    RevealZoom,

                    {% if plugins %}
                        {% for plugin in plugins %}
                            {% if plugin.name %}
                                {{ plugin.name }},
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                ],
            });
        </script>
    </body>
</html>